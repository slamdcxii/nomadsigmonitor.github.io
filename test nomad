<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>JSDF Strategic Forecast — April 2026</title>
<style>
  :root {
    --black: #000000;
    --dark: #0a0a0a;
    --dark2: #111111;
    --dark3: #1a1a1a;
    --border: #2a2a2a;
    --silver-dark: #888888;
    --silver: #b0b0b0;
    --silver-light: #cccccc;
    --silver-bright: #e0e0e0;
    --white: #f0f0f0;
    --accent: #c0c0c0;
    --red: #cc3333;
    --orange: #cc7733;
    --green: #336633;
    --blue: #334466;
    --glow: rgba(180,180,180,0.08);
  }
  * { margin: 0; padding: 0; box-sizing: border-box; }
  body {
    background: var(--black);
    color: var(--silver-light);
    font-family: 'Segoe UI', Arial, sans-serif;
    font-size: 13px;
    line-height: 1.5;
  }

  /* HEADER */
  .header {
    background: linear-gradient(135deg, #000 0%, #111 50%, #0a0a0a 100%);
    border-bottom: 1px solid #333;
    padding: 28px 40px;
    display: flex;
    align-items: center;
    gap: 28px;
    position: relative;
    overflow: hidden;
  }
  .header::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0; bottom: 0;
    background: radial-gradient(ellipse at 20% 50%, rgba(150,150,150,0.04) 0%, transparent 60%);
    pointer-events: none;
  }
  .header-logo {
    width: 72px;
    height: 72px;
    flex-shrink: 0;
  }
  .header-logo img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    filter: brightness(1.1);
  }
  .header-text { flex: 1; }
  .header-firm {
    font-size: 11px;
    letter-spacing: 4px;
    text-transform: uppercase;
    color: var(--silver-dark);
    margin-bottom: 6px;
  }
  .header-title {
    font-size: 26px;
    font-weight: 700;
    color: var(--silver-bright);
    letter-spacing: 2px;
    text-transform: uppercase;
  }
  .header-subtitle {
    font-size: 12px;
    color: var(--silver-dark);
    letter-spacing: 3px;
    text-transform: uppercase;
    margin-top: 6px;
  }
  .header-meta {
    text-align: right;
    font-size: 11px;
    color: var(--silver-dark);
    letter-spacing: 1px;
  }
  .header-meta .date { color: var(--silver); font-size: 13px; margin-bottom: 4px; }
  .header-meta .classif {
    display: inline-block;
    border: 1px solid #555;
    padding: 3px 10px;
    font-size: 10px;
    letter-spacing: 2px;
    color: var(--silver);
    margin-top: 6px;
  }

  /* NAV TABS */
  .nav {
    background: var(--dark2);
    border-bottom: 1px solid #222;
    display: flex;
    padding: 0 40px;
    gap: 4px;
    overflow-x: auto;
  }
  .nav-tab {
    padding: 14px 22px;
    font-size: 11px;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--silver-dark);
    cursor: pointer;
    border-bottom: 2px solid transparent;
    white-space: nowrap;
    transition: all 0.2s;
    user-select: none;
  }
  .nav-tab:hover { color: var(--silver-light); }
  .nav-tab.active {
    color: var(--silver-bright);
    border-bottom-color: var(--silver);
  }

  /* CONTENT */
  .content {
    padding: 32px 40px;
    max-width: 1600px;
    margin: 0 auto;
  }
  .section { display: none; }
  .section.active { display: block; }

  /* SECTION HEADERS */
  .section-header {
    display: flex;
    align-items: baseline;
    gap: 16px;
    margin-bottom: 24px;
    padding-bottom: 12px;
    border-bottom: 1px solid #222;
  }
  .section-title {
    font-size: 16px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 3px;
    color: var(--silver-bright);
  }
  .section-iq {
    font-size: 12px;
    color: var(--silver-dark);
    font-style: italic;
    letter-spacing: 1px;
  }

  /* CARDS */
  .card {
    background: var(--dark2);
    border: 1px solid #222;
    border-radius: 2px;
    padding: 18px 22px;
    margin-bottom: 12px;
    transition: border-color 0.2s;
  }
  .card:hover { border-color: #444; }
  .card-label {
    font-size: 10px;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: var(--silver-dark);
    margin-bottom: 8px;
  }
  .card-title {
    font-size: 13px;
    font-weight: 600;
    color: var(--silver-bright);
    margin-bottom: 8px;
  }
  .card-body {
    font-size: 12px;
    color: var(--silver);
    line-height: 1.7;
  }

  /* STEMPLES GRID */
  .stemples-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 3px;
    margin-bottom: 32px;
  }
  .stemples-cell {
    background: var(--dark2);
    border: 1px solid #1e1e1e;
    padding: 16px;
    min-height: 80px;
    transition: background 0.2s;
  }
  .stemples-cell:hover { background: #161616; }
  .stemples-header {
    background: #0d0d0d;
    padding: 12px 16px;
    font-size: 10px;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: var(--silver);
    font-weight: 700;
    border-bottom: 2px solid #333;
    text-align: center;
  }
  .stemples-entry {
    font-size: 11px;
    color: var(--silver);
    line-height: 1.6;
    margin-bottom: 10px;
    padding-bottom: 10px;
    border-bottom: 1px solid #1a1a1a;
  }
  .stemples-entry:last-child { border-bottom: none; margin-bottom: 0; padding-bottom: 0; }
  .stemples-num {
    font-size: 9px;
    color: var(--silver-dark);
    display: inline-block;
    width: 16px;
    flex-shrink: 0;
  }

  /* CATEGORY BADGE */
  .badge {
    display: inline-block;
    font-size: 9px;
    letter-spacing: 2px;
    text-transform: uppercase;
    padding: 2px 8px;
    border: 1px solid;
    margin-bottom: 8px;
  }
  .badge-military { color: #8899aa; border-color: #334455; }
  .badge-political { color: #aaa88a; border-color: #443322; }
  .badge-economic { color: #88aa88; border-color: #224422; }
  .badge-legal { color: #9988aa; border-color: #332244; }
  .badge-social { color: #aa8888; border-color: #442222; }
  .badge-tech { color: #88aaaa; border-color: #224444; }
  .badge-env { color: #99aa88; border-color: #334422; }
  .badge-security { color: #aa9988; border-color: #443322; }

  /* ASCOPE PMESII TABLE */
  .matrix-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 11px;
    margin-bottom: 24px;
  }
  .matrix-table th {
    background: #0d0d0d;
    padding: 10px 14px;
    text-align: left;
    font-size: 9px;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: var(--silver);
    border: 1px solid #1a1a1a;
    white-space: nowrap;
  }
  .matrix-table td {
    padding: 12px 14px;
    border: 1px solid #1a1a1a;
    vertical-align: top;
    color: var(--silver);
    line-height: 1.6;
    background: var(--dark2);
  }
  .matrix-table tr:hover td { background: #161616; }
  .matrix-table .row-header {
    background: #0f0f0f;
    color: var(--silver-light);
    font-size: 9px;
    letter-spacing: 2px;
    text-transform: uppercase;
    white-space: nowrap;
    font-weight: 700;
  }

  /* DRIVERS */
  .drivers-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 12px;
    margin-bottom: 24px;
  }
  .driver-card {
    background: var(--dark2);
    border: 1px solid #222;
    border-left: 3px solid #444;
    padding: 16px 20px;
    transition: border-color 0.2s;
  }
  .driver-card:hover { border-color: #555; border-left-color: #888; }
  .driver-cat {
    font-size: 9px;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: var(--silver-dark);
    margin-bottom: 8px;
  }
  .driver-text {
    font-size: 12px;
    color: var(--silver);
    line-height: 1.65;
    margin-bottom: 10px;
  }
  .driver-signals {
    margin-top: 8px;
    padding-top: 8px;
    border-top: 1px solid #1e1e1e;
    font-size: 10px;
    color: var(--silver-dark);
  }
  .driver-signals span { color: var(--silver); }

  /* CONE */
  .cone-timeline {
    display: grid;
    grid-template-columns: 140px 1fr 1fr 1fr 1fr;
    gap: 2px;
    margin-bottom: 24px;
  }
  .cone-row-label {
    display: flex;
    align-items: center;
    justify-content: flex-end;
    padding: 12px 14px;
    font-size: 9px;
    letter-spacing: 2px;
    text-transform: uppercase;
    font-weight: 700;
    color: var(--silver);
    background: #0d0d0d;
    border: 1px solid #1a1a1a;
  }
  .cone-header {
    background: #0d0d0d;
    padding: 10px 14px;
    font-size: 9px;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--silver);
    font-weight: 700;
    border: 1px solid #1a1a1a;
    text-align: center;
  }
  .cone-cell {
    background: var(--dark2);
    border: 1px solid #1a1a1a;
    padding: 14px;
    font-size: 11px;
    color: var(--silver);
    line-height: 1.65;
    min-height: 140px;
    vertical-align: top;
    transition: background 0.2s;
  }
  .cone-cell:hover { background: #161616; }
  .cone-cell.likely { border-left: 2px solid #336633; }
  .cone-cell.dangerous { border-left: 2px solid #663333; }
  .cone-cell.wildcard { border-left: 2px solid #335566; }
  .cone-cell.empty { background: #080808; }

  /* EFFECTS */
  .effect-card {
    background: var(--dark2);
    border: 1px solid #222;
    border-left: 3px solid #555;
    padding: 18px 22px;
    margin-bottom: 10px;
  }
  .effect-title {
    font-size: 10px;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: var(--silver-dark);
    margin-bottom: 10px;
  }
  .effect-body {
    font-size: 12px;
    color: var(--silver);
    line-height: 1.7;
  }
  .effect-card.effect-1 { border-left-color: #886633; }
  .effect-card.effect-2 { border-left-color: #668833; }
  .effect-card.effect-3 { border-left-color: #336688; }
  .effect-card.effect-4 { border-left-color: #663366; }

  /* OUTCOMES */
  .outcomes-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 24px;
    margin-bottom: 24px;
  }
  .outcome-section-title {
    font-size: 10px;
    letter-spacing: 3px;
    text-transform: uppercase;
    padding: 10px 16px;
    margin-bottom: 2px;
  }
  .outcome-title-preferred { background: #0a1a0a; color: #88bb88; }
  .outcome-title-undesired { background: #1a0a0a; color: #bb8888; }
  .outcome-item {
    background: var(--dark2);
    border: 1px solid #222;
    padding: 16px 20px;
    margin-bottom: 2px;
    font-size: 12px;
    color: var(--silver);
    line-height: 1.65;
  }

  /* SIGNALS TABLE */
  .signals-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 11px;
  }
  .signals-table th {
    background: #0d0d0d;
    padding: 10px 14px;
    text-align: left;
    font-size: 9px;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: var(--silver);
    border: 1px solid #1a1a1a;
  }
  .signals-table td {
    padding: 12px 14px;
    border: 1px solid #1a1a1a;
    vertical-align: top;
    background: var(--dark2);
    color: var(--silver);
    line-height: 1.6;
  }
  .signals-table tr:hover td { background: #161616; }

  /* FOOTER */
  .footer {
    background: #050505;
    border-top: 1px solid #1a1a1a;
    padding: 20px 40px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: 10px;
    color: #444;
    letter-spacing: 1px;
    margin-top: 60px;
  }
  .footer-center { text-align: center; }

  /* SCROLLBAR */
  ::-webkit-scrollbar { width: 6px; height: 6px; }
  ::-webkit-scrollbar-track { background: #111; }
  ::-webkit-scrollbar-thumb { background: #333; border-radius: 3px; }
  ::-webkit-scrollbar-thumb:hover { background: #555; }

  @media (max-width: 1100px) {
    .stemples-grid { grid-template-columns: repeat(2, 1fr); }
    .drivers-grid { grid-template-columns: 1fr; }
    .outcomes-grid { grid-template-columns: 1fr; }
    .cone-timeline { grid-template-columns: 100px 1fr 1fr; }
  }
  @media (max-width: 700px) {
    .content { padding: 20px 16px; }
    .header { padding: 20px 16px; }
    .nav { padding: 0 16px; }
    .stemples-grid { grid-template-columns: 1fr; }
    .cone-timeline { grid-template-columns: 90px 1fr; }
  }
</style>
</head>
